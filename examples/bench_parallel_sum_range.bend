leaf = Î»val Î»n Î»l (l val)
node = Î»lft Î»rgt Î»n Î»l (n lft rgt)

height = 19
main = (sum (make height 0))

make = Î»h switch h { 0: make_leaf _: (make_node h-1) }
make_leaf = Î»n (leaf n)
make_node = Î»h-1 Î»n (node (make h-1 (* 2 n)) (make h-1 (+ 1 (* 2 n))))

sum = Î»t (t sum_node sum_leaf)
sum_node = Î»lft Î»rgt (+ (sum lft) (sum rgt))
sum_leaf = Î»val val
